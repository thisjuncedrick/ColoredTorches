<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<AssemblyName>ColoredTorches</AssemblyName>

		<UniqueId>ceddieeee.ColoredTorches</UniqueId>
		<Name>Colored Torches</Name>
		<Authors>ceddieeee</Authors>
		<Description>Adds a craftable colored torch variants</Description>
		<Version>1.0.1</Version>
		<MinimumApiVersion>auto</MinimumApiVersion>
		<MinimumGameVersion_Behavior>SetFull</MinimumGameVersion_Behavior>
		<UpdateKeys>Nexus:45289</UpdateKeys>
	</PropertyGroup>

	<PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
		<EnableHarmony>true</EnableHarmony>
  </PropertyGroup>

	<ItemGroup>
		<ContentPacks Include="[CP] ColoredTorches" Version="$(Version)" />
	</ItemGroup>

  <ItemGroup>
    <PackageReference Include="Leclair.Stardew.ModManifestBuilder" Version="2.4.1" />
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.4.0" />
    <PackageReference Include="Pathoschild.Stardew.ModTranslationClassBuilder" Version="2.2.1" />
  </ItemGroup>
</Project>
